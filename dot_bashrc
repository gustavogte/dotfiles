# ~/.bashrc

# Hello Gus2

eval "$(starship init bash)"

alias cl="clear"
alias python="python3"
alias pip="pip3"
alias c="clear"
alias g="git"
alias gs="git status"
alias ga="git add"
alias gc="git commit"
alias gp="git push"
alias gl="git log"
alias gd="git diff"
alias gr="git log --all --decorate --graph"
alias grr="git log --graph --all --date=human --decorate --pretty='%C(yellow)H:%h %C(blue) %ar %C(red) => %s %C(white)> %ae'"
alias t="tmux"
alias v="nvim"
alias e="exit"
alias h="history"
alias p="pwd"
alias l="ls"
alias ll="ls -l"
alias la="ls -a"
alias lla="ls -la"
alias nano="/opt/homebrew/bin/nano"
eval "$(zoxide init bash)"
alias z="zoxide"


# This is a coommon configurtion for Alcracitty
#eval "$(starship init zsh)"

export PATH="$PATH:/usr/local/bin"
export PATH="/opt/homebrew/opt/openjdk/bin:$PATH"

. "$HOME/.cargo/env"
